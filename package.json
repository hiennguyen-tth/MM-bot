{
    "name": "mm-bot",
    "version": "1.0.0",
    "description": "Market Making Bot – 4-layer risk (T1-T4) with adaptive spread and inventory skew",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "node --watch src/index.js",
        "test": "jest --coverage --forceExit",
        "test:unit": "jest tests/unit --coverage --forceExit",
        "test:integration": "jest tests/integration --forceExit",
        "test:live": "node scripts/test-bingx-live.js"
    },
    "dependencies": {
        "ccxt": "^4.3.0",
        "dotenv": "^16.4.5",
        "winston": "^3.13.0"
    },
    "devDependencies": {
        "jest": "^29.7.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "src/**/*.js"
        ],
        "coverageThreshold": {
            "global": {
                "lines": 70
            }
        }
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "license": "MIT"
}