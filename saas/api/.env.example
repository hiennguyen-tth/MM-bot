# ── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=24h

# ── Encryption (API keys at rest) ─────────────────────────────────────────────
# MUST be exactly 64 hex chars (32 bytes). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGDATABASE=mmbot
PGUSER=mmbot
PGPASSWORD=REPLACE_WITH_DB_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend domain in production, e.g. https://app.yourdomain.com
CORS_ORIGIN=*

# ── BTC reference price (for converting capital USDT → BTC sizes) ─────────────
# Update periodically; ~15% off won't matter much for sizing
BTC_PRICE_USDT=75000

# ── Global kill switch (set to 'true' to stop ALL running bots) ───────────────
GLOBAL_KILL_SWITCH=false

# ── Telegram (platform bot for user notifications) ───────────────────────────
# 1. Create a bot at @BotFather → get BOT_TOKEN
# 2. Users start a chat with your bot, then call PUT /auth/telegram { chatId }
#    to register their chat_id (from https://api.telegram.org/bot<TOKEN>/getUpdates)
# Leave empty to disable Telegram notifications entirely.
TELEGRAM_BOT_TOKEN=
