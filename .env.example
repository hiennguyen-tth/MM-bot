# ─────────────────────────────────────────────────────────────────────────────
# MM BOT v2 – Environment Configuration
#
# HƯỚNG DẪN: cp .env.example .env → điền API key → chạy npm start
# NEVER commit .env vào git (đã có trong .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Exchange credentials ─────────────────────────────────────────────────────
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# ─── Exchange ─────────────────────────────────────────────────────────────────
# Supported: binance | bingx
EXCHANGE=binance

# TESTNET=true  → dùng testnet (KHÔNG mất tiền thật, nên để true khi test)
# TESTNET=false → mainnet (TIỀN THẬT)
#
#   Binance testnet: https://testnet.binance.vision/key/generate
#   BingX testnet:   chỉ có cho swap (futures). Spot phải dùng mainnet với size nhỏ.
TESTNET=true

# BingX chỉ: spot | swap (perpetual)
MARKET_TYPE=spot

# ─── Market ───────────────────────────────────────────────────────────────────
# spot  → BTC/USDT
# swap  → BTC/USDT:USDT  (BingX perpetuals)
SYMBOL=BTC/USDT

# ─── Spread engine ────────────────────────────────────────────────────────────
# Formula: spread = max(2×fee, BASE_SPREAD × (1 + VOL_MULTIPLIER × vol))
#          vol    = std(last VOL_LOOKBACK trade prices) / mid
#
# Binance Spot maker fee: 0.1% → FEE=0.001
# BingX   Spot maker fee: 0.02% → FEE=0.0002
BASE_SPREAD=0.002
FEE=0.001
VOL_LOOKBACK=20
VOL_MULTIPLIER=3

# ─── Orderbook imbalance spread ───────────────────────────────────────────────
# Spreads wider khi book lệch (bảo vệ khỏi "runover")
# imbalance = (bidVol - askVol) / total  ∈ [-1, 1]
# spread    = max(vol_spread, IMBALANCE_FACTOR × |imbalance|)
IMBALANCE_ENABLED=true
IMBALANCE_FACTOR=0.003

# ─── Dynamic spread (regime-aware) ───────────────────────────────────────────
DYNAMIC_SPREAD_ENABLED=true
SPREAD_MIN_MULT=0.5
SPREAD_MAX_MULT=3.0
# Hard cap: spread không bao giờ vượt quá giá trị này (5%)
SPREAD_MAX_FRACTION=0.05
# Spread multiplier theo từng regime
SPREAD_MULT_TREND_UP=1.5
SPREAD_MULT_TREND_DOWN=1.5
SPREAD_MULT_RANGING=1.0
SPREAD_MULT_VOLATILE=2.0

# ─── Multi-level quoting ──────────────────────────────────────────────────────
# Bot đặt N cặp lệnh mỗi cycle (L1 tight, L2/L3 wider = passive insurance)
# QUOTE_LEVELS=1  – 1 bid + 1 ask (đơn giản nhất, dùng khi test $20)
# QUOTE_LEVELS=3  – 3 bids + 3 asks (prod, tăng fill rate)
QUOTE_LEVELS=3

# ─── Adaptive timing ─────────────────────────────────────────────────────────
# Loop interval co dãn theo vol: vol cao → loop nhanh hơn
ADAPTIVE_TIMING_ENABLED=true
TIMING_MIN_INTERVAL_MS=500
TIMING_MAX_INTERVAL_MS=5000
TIMING_FILL_POLL_FAST_MS=250
TIMING_FILL_POLL_SLOW_MS=1000
TIMING_VOL_HIGH=0.005
TIMING_VOL_LOW=0.001

# ─── Regime detection ─────────────────────────────────────────────────────────
REGIME_ENABLED=true
REGIME_MOMENTUM_WINDOW=10
REGIME_TREND_THRESHOLD=0.002
REGIME_VOLATILE_THRESHOLD=0.006

# ─── Regime filter (dừng quote khi market đột biến) ──────────────────────────
# Nếu giá di chuyển > REGIME_FILTER_MAX_MOVE trong 1 phút → pause REGIME_FILTER_PAUSE_MS
# Bảo vệ khi có tin tức, liquidity event, v.v.
REGIME_FILTER_ENABLED=true
# 1% trong 1 phút → pause  (prod: 0.005 = 0.5%, test: 0.02 = 2%)
REGIME_FILTER_MAX_MOVE=0.01
REGIME_FILTER_PAUSE_MS=45000

# ─── Latency protection ───────────────────────────────────────────────────────
# Cancel quotes ngay nếu mid drift > ngưỡng trong khi quotes đang live
# Tránh HFT pick off stale quotes
LATENCY_PROTECTION_ENABLED=true
# 0.1% = 0.001  (prod: 0.001, test có thể để 0.005)
LATENCY_CANCEL_THRESHOLD=0.001

# ─── Inventory limits ─────────────────────────────────────────────────────────
# SOFT_MAX / HARD_MAX tính theo base currency (BTC)
#
# Config $20 test: BASE_SIZE=0.00001, SOFT_MAX=0.0001, HARD_MAX=0.0002
# Config prod BTF: BASE_SIZE=0.001,   SOFT_MAX=0.1,    HARD_MAX=0.2
SOFT_MAX=0.1
HARD_MAX=0.2
SKEW_FACTOR=0.3
SIZE_FACTOR=0.8
BASE_SIZE=0.001

# ─── Inventory VaR (tự động giảm exposure khi vol cao) ────────────────────────
# effectiveHardMax = min(HARD_MAX, CAPITAL_USDT / (vol × VAR_MULTIPLIER))
# vol cao → hardMax thu nhỏ → auto giảm position risk
INV_VAR_ENABLED=false
CAPITAL_USDT=1000
VAR_MULTIPLIER=100

# ─── Hedging preference ───────────────────────────────────────────────────────
# true  → thử limit hedge trước (ít fee + slippage), fallback sang market nếu timeout
# false → market order ngay (chắc chắn fill, nhưng tốn fee + slippage)
HEDGE_PREFER_LIMIT=true
HEDGE_LIMIT_TIMEOUT_MS=2000

# ─── Risk / Circuit breaker ───────────────────────────────────────────────────
# Bot SHUTDOWN hoàn toàn nếu vượt ngưỡng:
#
# Config $20 test: DAILY_LOSS_LIMIT=2, CONSECUTIVE_LOSS=3
# Config prod:     DAILY_LOSS_LIMIT=50, CONSECUTIVE_LOSS=5
DAILY_LOSS_LIMIT=50
CONSECUTIVE_LOSS=5
ADVERSE_FILL_RATIO=0.6
ADVERSE_FILL_WINDOW=20

# ─── Time-of-day adjustment ───────────────────────────────────────────────────
# Tự động mở rộng spread + giảm size trong phiên US (volatile hơn)
# false = tắt  (ổn định hơn khi test)
TIME_OF_DAY_ENABLED=false
US_SESSION_START_UTC=13
US_SESSION_END_UTC=22
US_SPREAD_MULT=1.5
US_SIZE_MULT=0.7

# ─── Loop timing (static, chỉ dùng khi ADAPTIVE_TIMING_ENABLED=false) ────────
LOOP_INTERVAL_MS=2000
FILL_POLL_MS=500
# ⚠️ Giảm xuống 2500ms (vs 8000ms cũ) – tránh stale quote bị HFT pick off
ORDER_TTL_MS=2500

# ─── Telegram alerts ─────────────────────────────────────────────────────────
# Bot sẽ gửi thông báo khi SHUTDOWN và báo cáo lợi nhuận định kỳ qua Telegram.
#
# Setup:
#   1. Chat với @BotFather → /newbot → lấy TOKEN
#   2. Nhắn bất kỳ thứ gì cho bot → vào:
#      https://api.telegram.org/bot<TOKEN>/getUpdates → lấy "id" trong "chat"
#   3. Điền vào đây:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Tần suất gửi báo cáo lợi nhuận (ms, mặc định 30 phút = 1800000)
TELEGRAM_METRICS_INTERVAL_MS=1800000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
